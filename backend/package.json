    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.4",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.7.0",
